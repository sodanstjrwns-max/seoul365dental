{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seoul365dental",
  "compatibility_date": "2026-02-21",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [{ "binding": "DB", "database_name": "seoul365-production", "database_id": "a63b49ed-8ee6-4657-b576-28807521c191" }],
  "r2_buckets": [{ "binding": "R2", "bucket_name": "seoul365-uploads" }]
}
