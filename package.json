{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "css:build": "npx tailwindcss -c tailwind.config.cjs -i src/styles/main.css -o public/static/style.css --minify",
    "build": "npm run css:build && vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5",
    "wrangler": "^4.78.0"
  }
}
